<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔧 SERVICE HUB"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#1E3A8A"/>

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <Button
        android:id="@+id/btnProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:layout_marginTop="25dp"
        android:backgroundTint="#1E3A8A"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnBecomeProvider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Become Provider"
        android:layout_marginTop="12dp"
        android:backgroundTint="#F97316"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnUpdateLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍 Update My Location"
        android:layout_marginTop="12dp"
        android:backgroundTint="#10B981"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:layout_marginTop="12dp"
        android:backgroundTint="#1E3A8A"
        android:textColor="#FFFFFF"/>

</LinearLayout>